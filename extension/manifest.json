{
  "manifest_version": 3,
  "name": "Real-Time Hate Speech Detector",
  "description": "Automatically detects and highlights hate speech on social media in real time using AI.",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://127.0.0.1:5001/*",
    "http://localhost:5001/*",
    "https://*.twitter.com/*",
    "https://twitter.com/*",
    "https://*.x.com/*",
    "https://x.com/*",
    "https://*.youtube.com/*",
    "https://youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.twitter.com/*",
        "https://twitter.com/*",
        "https://*.x.com/*",
        "https://x.com/*",
        "https://*.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}